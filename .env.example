# Plantilla de variables de entorno.
# Copiá este archivo como ".env.local" y pegá tu clave real de Google Gemini.
# Conseguí tu clave gratis en: https://aistudio.google.com/apikey

GEMINI_API_KEY=tu_clave_aca

# Supabase (autenticación). Las encontrás en tu proyecto: botón "Connect".
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_tu_clave
